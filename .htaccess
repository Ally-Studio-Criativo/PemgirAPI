<IfModule mod_rewrite.c>
Options +FollowSymLinks
RewriteEngine On

# Bloquear acesso a arquivos sensíveis
RewriteRule ^\.env - [F,L]
RewriteRule ^\.git - [F,L]

# Permitir acesso direto à pasta storage (redirecionar para public/storage)
RewriteCond %{REQUEST_URI} ^/storage/
RewriteRule ^storage/(.*)$ /public/storage/$1 [L]

# Se não começar com /public/, redirecionar arquivos e diretórios para public/
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ /public/$1

# Redirecionar raiz para public/index.php
RewriteRule ^(/)?$ public/index.php [L]
</IfModule>
